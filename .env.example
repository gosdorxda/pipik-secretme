# ── WAJIB ──────────────────────────────────────────────────────────────────
NODE_ENV=production
DATABASE_URL=postgresql://whisperbox:password@localhost:5432/whisperbox
APP_URL=https://domainmu.com

# Clerk Authentication — ambil dari https://dashboard.clerk.com → API Keys
# Gunakan pk_live_... dan sk_live_... untuk production
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxx

# Clerk Proxy URL — opsional, isi jika pakai custom domain dengan Clerk proxy
# CLERK_PROXY_URL=https://domainmu.com/api/__clerk

# Admin Panel — string acak bebas, minimal 32 karakter
ADMIN_SECRET=

# Session Secret — untuk hashing IP (rate limiting), string acak bebas
SESSION_SECRET=

# ── PEMBAYARAN (TriPay) ─────────────────────────────────────────────────────
# Ambil dari https://tripay.co.id/member/merchant
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
# Hapus baris ini atau set ke "false" untuk mode production
# TRIPAY_SANDBOX=true

# ── EMAIL (Resend) ───────────────────────────────────────────────────────────
# Ambil dari https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Domain harus sudah diverifikasi di Resend
RESEND_FROM_EMAIL=noreply@domainmu.com

# ── ANTI-SPAM (Cloudflare Turnstile) ────────────────────────────────────────
# Ambil dari https://dash.cloudflare.com → Turnstile → Secret Key
TURNSTILE_SECRET_KEY=

# ── OPSIONAL ────────────────────────────────────────────────────────────────
# Level log: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info
# Harga premium dalam rupiah tanpa koma (default: 49900)
PREMIUM_PRICE=49900
