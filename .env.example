# ── WAJIB ──────────────────────────────────────────────────────────────────
NODE_ENV=production
DATABASE_URL=postgresql://vooi:ganti_password_kuat@localhost:5432/vooi
APP_URL=https://vooi.lol

# Clerk Authentication — ambil dari https://dashboard.clerk.com → API Keys
# Gunakan pk_live_... dan sk_live_... untuk production (bukan pk_test_)
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxx

# Clerk Proxy URL — opsional, isi jika pakai Clerk proxy di domain custom
# CLERK_PROXY_URL=https://vooi.lol/api/__clerk

# Admin Panel — string acak bebas, minimal 32 karakter
ADMIN_SECRET=

# Session Secret — salt untuk hashing IP (rate limiting), string acak berbeda dari ADMIN_SECRET
SESSION_SECRET=

# ── PEMBAYARAN (TriPay) ─────────────────────────────────────────────────────
# Ambil dari https://tripay.co.id/member/merchant
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
# Hapus baris ini atau set ke "false" untuk mode production
# TRIPAY_SANDBOX=true

# ── EMAIL (Resend) ───────────────────────────────────────────────────────────
# Ambil dari https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Wajib format email lengkap, domain harus sudah diverifikasi di Resend
RESEND_FROM_EMAIL=noreply@vooi.lol

# ── OPSIONAL ────────────────────────────────────────────────────────────────
# Level log: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info
# Harga premium dalam rupiah tanpa koma (default: 49900)
PREMIUM_PRICE=49900
